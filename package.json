{
  "private": true,
  "name": "mocha",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:docs": "cd apps/docs && mintlify dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\""
  },
  "devDependencies": {
    "mintlify": "latest",
    "prettier": "^2.5.1",
    "turbo": "^2.0.3"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "packageManager": "bun@1.3.13",
  "dependencies": {
    "fastify": "^5.1.0"
  },
  "resolutions": {
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3"
  }
}